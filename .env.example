# Database
DATABASE_URL=local.db

# File uploads
UPLOAD_PATH=./uploads

# Public base URL — used to generate QR code links
BASE_URL=https://fishing.yourdomain.com

# Optional: set to enable multi-user authentication
# Leave unset to run the app fully open (single-tenant, no login).
ADMIN_PASSWORD=

# Optional: SMTP server for "forgot password" reset emails. When unset, the forgot-password
# feature is hidden. Requires at least SMTP_HOST and SMTP_FROM. BASE_URL is used for the link.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587                       # 465 implies TLS; otherwise STARTTLS
# SMTP_SECURE=false                   # set true for port 465
# SMTP_USER=apikey                    # omit for unauthenticated relays
# SMTP_PASS=secret
# SMTP_FROM=OpenFishing <noreply@example.com>

# Optional: set to any value to enable read-only demo mode
# All writes are blocked; a banner and toast inform visitors
# DEMO_MODE=1

# Optional: AI chatbot (floating chat widget powered by LiteLLM)
# Set CHATBOT=true and point to your LiteLLM proxy to enable.
# See docker-compose.yml and litellm.config.yaml for the full setup.
# CHATBOT=true
# LITELLM_URL=http://litellm:4000
# LITELLM_MODEL=claude-sonnet   # must match a model_name in litellm.config.yaml

# API keys — passed to the LiteLLM container via docker-compose.yml
# Only the key for your chosen model is required.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
