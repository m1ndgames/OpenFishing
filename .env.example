# Database
DATABASE_URL=local.db

# File uploads
UPLOAD_PATH=./uploads

# Public base URL — used to generate QR code links
BASE_URL=https://fishing.yourdomain.com

# Optional: set to enable password authentication
# Leave unset to run the app without any login prompt
AUTH_PASSWORD=

# Optional: set to any value to enable read-only demo mode
# All writes are blocked; a banner and toast inform visitors
# DEMO_MODE=1
