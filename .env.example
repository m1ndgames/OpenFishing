# Database
DATABASE_URL=local.db

# File uploads
UPLOAD_PATH=./uploads

# Public base URL — used to generate QR code links
BASE_URL=https://fishing.yourdomain.com

# Optional: set to enable password authentication
# Leave unset to run the app without any login prompt
AUTH_PASSWORD=

# Optional: set to any value to enable read-only demo mode
# All writes are blocked; a banner and toast inform visitors
# DEMO_MODE=1

# Optional: AI chatbot (floating chat widget powered by LiteLLM)
# Set CHATBOT=true and point to your LiteLLM proxy to enable.
# See docker-compose.yml and litellm.config.yaml for the full setup.
# CHATBOT=true
# LITELLM_URL=http://litellm:4000
# LITELLM_MODEL=claude-sonnet   # must match a model_name in litellm.config.yaml

# API keys — passed to the LiteLLM container via docker-compose.yml
# Only the key for your chosen model is required.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
